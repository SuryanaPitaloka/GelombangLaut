<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_ocean">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <ImageView
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:layout_gravity="center"
            android:src="@android:drawable/ic_menu_compass"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="Prediksi Gelombang Laut"
            android:textColor="@android:color/white"
            android:textSize="30sp"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginBottom="24dp"
            android:text="Masukkan 5 data tinggi gelombang"
            android:textColor="#E3F2FD"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_white"
            android:elevation="8dp"
            android:padding="20dp">

            <EditText
                android:id="@+id/et1"
                style="@style/InputStyle"
                android:hint="🌊 Tinggi Gelombang 1"/>

            <EditText
                android:id="@+id/et2"
                style="@style/InputStyle"
                android:hint="🌊 Tinggi Gelombang 2"/>

            <EditText
                android:id="@+id/et3"
                style="@style/InputStyle"
                android:hint="🌊 Tinggi Gelombang 3"/>

            <EditText
                android:id="@+id/et4"
                style="@style/InputStyle"
                android:hint="🌊 Tinggi Gelombang 4"/>

            <EditText
                android:id="@+id/et5"
                style="@style/InputStyle"
                android:hint="🌊 Tinggi Gelombang 5"/>

            <Button
                android:id="@+id/btnPrediksi"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="12dp"
                android:backgroundTint="#1565C0"
                android:text="🌊 PREDIKSI"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:textStyle="bold"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/card_white"
            android:elevation="8dp"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📊 HASIL PREDIKSI"
                android:textSize="18sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvHasil"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="-"
                android:textColor="#0D47A1"
                android:textSize="30sp"
                android:textStyle="bold"/>

        </LinearLayout>

    </LinearLayout>

</ScrollView>